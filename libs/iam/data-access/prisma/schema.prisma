datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // ✨ Connects to NeonDB
}

generator client {
  provider = "prisma-client-js"
  output   = "../../../../node_modules/@prisma/client-iam"
}

enum UserStatus {
  PENDING
  ACTIVE
  LOCKED
  SUSPENDED
}

model Tenant {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(100)
  isActive    Boolean   @default(true) @map("is_active")
  
  users       User[]
  
  // Audit Trails
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  @@map("tenants") // Standardize table name to lowercase plural
}

model User {
  id                    String     @id @default(uuid()) @db.Uuid
  tenantId              String     @db.Uuid @map("tenant_id")
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  
  email                 String     @unique @db.VarChar(255)
  passwordHash          String     @map("password_hash")
  
  // Identity
  firstName             String?    @map("first_name") @db.VarChar(100)
  lastName              String?    @map("last_name") @db.VarChar(100)
  
  // Security & Access Control
  status                UserStatus @default(PENDING)
  mfaEnabled            Boolean    @default(false) @map("mfa_enabled")
  mfaSecret             String?    @map("mfa_secret")
  failedLoginAttempts   Int        @default(0) @map("failed_login_attempts")
  lockedUntil           DateTime?  @map("locked_until")
  passwordChangedAt     DateTime?  @map("password_changed_at")
  lastLoginAt           DateTime?  @map("last_login_at")
  
  sessions              Session[]
  
  // Audit Trails
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")
  deletedAt             DateTime?  @map("deleted_at") // For Soft Deletes

  // Fast lookups for authentication
  @@index([tenantId, email])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @db.Uuid @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Security tracking
  ipAddress    String?  @map("ip_address") @db.Inet // Postgres specific IP type
  userAgent    String?  @map("user_agent")
  
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("sessions")
}