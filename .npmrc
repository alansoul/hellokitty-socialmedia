# 1. Keep your critical PNPM Hoisting configurations for Prisma
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=@prisma/client

# 2. Force all standard public packages (like @types/* and postcss) to pull from npm
registry=https://registry.npmjs.org/

# 3. Only route your specific GitHub account packages to GitHub Packages
# (Replace '@alansoul' with your actual GitHub username/scope if you publish custom packages there)
@alansoul:registry=https://npm.pkg.github.com/

# Always authenticate for your scoped registry
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}