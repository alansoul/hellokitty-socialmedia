  "scripts": {
    "dev:web": "nx serve web",
    "dev:auth": "nx serve auth-api",
    "dev:social": "nx serve social-api",
    "dev:all": "nx run-many --target=serve --projects=auth-api,social-api,worker,web,auth-web --parallel=5 --output-style=stream",
    "build:all": "nx run-many --target=build --all --parallel=3",
    "postinstall": "pnpm prisma:generate:all",
    "prisma:generate:all": "npx prisma generate --schema=libs/iam/data-access/prisma/schema.prisma && npx prisma generate --schema=libs/social/data-access/prisma/schema.prisma",
    "prepare": "husky",
    "db:iam:push": "npx prisma db push --schema=libs/iam/data-access/prisma/schema.prisma",
    "db:iam:generate": "npx prisma generate --schema=libs/iam/data-access/prisma/schema.prisma",
    "db:social:push": "npx prisma db push --schema=libs/social/data-access/prisma/schema.prisma",
    "db:social:generate": "npx prisma generate --schema=libs/social/data-access/prisma/schema.prisma",
    "db:iam:studio": "npx prisma studio --schema=libs/iam/data-access/prisma/schema.prisma"
  },
